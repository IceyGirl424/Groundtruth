# Groundtruth secrets — copy this file to `.env` and fill in real values.
# `.env` is gitignored and must NEVER be committed.

# Anthropic (Claude reasoning + LLM-as-judge)
ANTHROPIC_API_KEY="sk-ant-..."

# Redis Cloud (agent memory: RedisVL vector index)
REDIS_URL="redis://default:<password>@<host>:<port>"

# Arize AX (LLM tracing + evaluation dashboard)
ARIZE_SPACE_ID="your-arize-space-id"
ARIZE_API_KEY="ak-..."

# Fetch.ai Agentverse API token.
# Injected for completeness; the coordinator's mailbox is claimed interactively
# via the Agentverse inspector, so this is not strictly required to run locally.
AGENTVERSE_API_TOKEN="your-agentverse-api-token"
